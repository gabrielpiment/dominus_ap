# Supabase Configuration
# (For local dev, Nuxt Supabase reads SUPABASE_URL and SUPABASE_KEY. 
# For Vercel production, it is recommended to set them as NUXT_PUBLIC_SUPABASE_URL and NUXT_PUBLIC_SUPABASE_KEY)
SUPABASE_URL="https://usazqzyuqzuyktrymdvc.supabase.co"
SUPABASE_KEY="your-anon-key-here"

# Nuxt Public variables (exposed to client side)
NUXT_PUBLIC_SUPABASE_URL="https://usazqzyuqzuyktrymdvc.supabase.co"
NUXT_PUBLIC_SUPABASE_KEY="your-anon-key-here"

# Cal.com Link Configuration
NUXT_PUBLIC_CAL_LINK="metodo-dominus/60min"
